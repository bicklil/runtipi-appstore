{
    "schemaVersion": 2,
    "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
    "services": [
        {
            "name": "classement",
            "isMain": true,
            "image": "localhost:42420/classement-voile:latest",
            "internalPort": 3333,
            "addPorts": [
                {
                    "containerPort": 3333,
                    "hostPort": 3333
                }
            ],
            "volumes": [
                {
                "hostPath": "${APP_DATA_DIR}/data",
                "containerPath": "/app/data"
                },
                {
                "hostPath": "${APP_DATA_DIR}/exemple_classement",
                "containerPath": "/app/exemple_classement"
                }
            ],
            "addToMainNetwork": true
        }
    ]
}